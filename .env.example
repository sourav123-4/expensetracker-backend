# Server
NODE_ENV=development
PORT=8000
API_PREFIX=/api/v1
CORS_ORIGIN=*

# MongoDB — no local mongod/Docker available in the dev sandbox this was built in;
# point this at a local install or a free MongoDB Atlas cluster to run in dev mode.
# Automated tests do NOT need this — they spin up mongodb-memory-server.
MONGODB_URI=mongodb://127.0.0.1:27017/expenseflow

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Cloudinary (receipt uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (OTP delivery) — leave blank in dev to fall back to console-logged OTPs
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ExpenseFlow <no-reply@expenseflow.app>"

# Rate limiting
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=5

# Firebase Admin (push notifications AND verifying phone sign-in ID tokens) —
# set either the full JSON string (good for Vercel) or a local path to the
# downloaded service-account JSON. Empty = both features disabled.
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Google Sign-In — the "Web client" OAuth ID from Firebase Console → Authentication →
# Sign-in method → Google (enabling it auto-creates this). The mobile app's
# GoogleSignin.configure() must use this SAME id as webClientId — that's what makes the
# ID token's audience match this value. Empty = /auth/google returns 400.
GOOGLE_WEB_CLIENT_ID=

# Google Gemini — free-tier API key from https://aistudio.google.com/apikey, used to
# suggest an expense category from its title. Empty = /expenses/categorize returns 400.
GEMINI_API_KEY= 
